{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm run *)",
      "Bash(node scripts/*)",
      "Bash(node --check *)",
      "Bash(grep *)",
      "Bash(ls *)"
    ],
    "deny": [
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git clean*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh ./scripts/ecosystem-orient.sh"
          }
        ]
      }
    ]
  }
}
