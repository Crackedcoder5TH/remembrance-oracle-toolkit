# Remembrance Ecosystem — Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ─── LLM API Keys (at least one required for Swarm) ──────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROK_API_KEY=
DEEPSEEK_API_KEY=

# ─── GitHub (required for Reflector PR integration) ───────────────
GITHUB_TOKEN=

# ─── Service Ports ────────────────────────────────────────────────
ORACLE_PORT=3000
VOID_PORT=8080
REFLECTOR_PORT=3001
SWARM_PORT=3002

# ─── Oracle Configuration ────────────────────────────────────────
ORACLE_THRESHOLD=0.6
ORACLE_AUTO_SEED=true
ORACLE_DEBUG=false

# ─── Void Compressor Configuration ───────────────────────────────
VOID_COMPRESSION_LEVEL=adaptive
VOID_SUBSTRATE_DIR=/app/substrates

# ─── Reflector Configuration ─────────────────────────────────────
REFLECTOR_MODE=balanced
REFLECTOR_MIN_COHERENCE=0.68

# ─── Repo Paths (relative to docker-compose.yml) ─────────────────
VOID_COMPRESSOR_PATH=../Void-Data-Compressor
REFLECTOR_PATH=../Reflector-oracle-
SWARM_PATH=../REMEMBRANCE-AGENT-Swarm-

# ─── Cross-Service URLs (only if NOT using docker-compose) ────────
# ORACLE_TOOLKIT_URL=http://localhost:3000
# VOID_COMPRESSOR_URL=http://localhost:8080
