# =============================================================================
# Valor Legacies — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# =============================================================================

# --- Public ---
# Site URL (used for sitemap, robots.txt, Open Graph, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# --- Google OAuth (NextAuth) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Must match your deployed URL (or http://localhost:3000 for dev)
NEXTAUTH_URL=http://localhost:3000

# --- Admin ---
# API key for admin dashboard access (min 16 chars recommended)
# Without this, /admin and /api/admin/* routes return 503
ADMIN_API_KEY=
# Comma-separated Google emails that get admin access after signing in
# e.g. alice@gmail.com,bob@gmail.com
ADMIN_EMAILS=Ajanichisolm@gmail.com

# --- Email (SMTP) ---
# SMTP server for sending lead confirmation emails
# If SMTP_HOST is not set, emails are logged to console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com
COMPANY_NAME=Your Company Name
# Admin notification email — receives new lead alerts
ADMIN_EMAIL=

# --- Analytics ---
# Google Ads conversion ID (optional)
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=

# --- Logging ---
# Minimum log level: debug, info, warn, error (default: info in production, debug in dev)
LOG_LEVEL=

# --- Webhooks ---
# Comma-separated webhook URLs to receive lead events
# Leave empty to disable webhook delivery
WEBHOOK_URLS=
# Shared secret for HMAC-SHA256 webhook signatures
WEBHOOK_SECRET=
