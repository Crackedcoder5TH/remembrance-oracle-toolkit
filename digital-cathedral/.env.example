# =============================================================================
# Valor Legacies — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# [REQUIRED] = must be set before deploying to production
# [OPTIONAL] = enables extra features when provided
# =============================================================================

# --- Public ---
# Site URL (used for sitemap, robots.txt, Open Graph, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://valorlegacies.com

# --- Admin ---
# API key for admin dashboard access (min 16 chars recommended)
# Used for API key login fallback and bearer token auth
ADMIN_API_KEY=
# [REQUIRED] Google emails with admin access (comma-separated)
ADMIN_EMAILS=you@gmail.com

# --- Google OAuth (NextAuth) ---
# [REQUIRED] Create at https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# [REQUIRED] Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=
# Your site URL (http://localhost:3000 for local dev)
NEXTAUTH_URL=https://valorlegacies.com

# --- Database ---
# [REQUIRED for production] PostgreSQL connection string
# Free hosted options: https://neon.tech or https://supabase.com
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
# Without this, falls back to SQLite (local dev only — ephemeral on Vercel)
DATABASE_URL=

# --- Email (SMTP) ---
# [OPTIONAL] SendGrid recommended — https://sendgrid.com
# Without SMTP_HOST, emails log to console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@valorlegacies.com
COMPANY_NAME=Valor Legacies
# [OPTIONAL] Admin receives email for each new lead
ADMIN_EMAIL=

# --- Analytics ---
# [OPTIONAL] Google Analytics GA4 — https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# [OPTIONAL] Google Ads conversion tracking
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=
# [OPTIONAL] Meta/Facebook Pixel — https://business.facebook.com
NEXT_PUBLIC_META_PIXEL_ID=

# --- Sentry Error Monitoring ---
# [OPTIONAL] Get DSN from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=

# --- Twilio SMS ---
# [OPTIONAL] Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# [OPTIONAL] Admin phone for SMS alerts on new leads (e.g., +15551234567)
ADMIN_PHONE=

# --- CRM Integration ---
# [OPTIONAL] "hubspot" or "salesforce" (leave empty to skip)
CRM_PROVIDER=
# [OPTIONAL] CRM API key (HubSpot private app token or Salesforce access token)
CRM_API_KEY=
# [OPTIONAL] Salesforce instance URL only
CRM_INSTANCE_URL=

# --- Webhooks ---
# [OPTIONAL] Comma-separated webhook URLs for lead notification
WEBHOOK_URLS=
# Shared secret for HMAC-SHA256 webhook signatures
WEBHOOK_SECRET=

# --- Logging ---
# Minimum log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
