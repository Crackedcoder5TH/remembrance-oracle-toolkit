{
  "name": "remembrance-oracle-toolkit",
  "version": "3.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "remembrance-oracle-toolkit",
      "version": "3.1.0",
      "hasInstallScript": true,
      "license": "MIT",
      "workspaces": [
        "packages/*",
        "tools/*"
      ],
      "bin": {
        "oracle": "src/cli.js",
        "reflector": "bin/reflector",
        "remembrance-oracle": "src/cli.js"
      },
      "engines": {
        "node": ">=22.0.0",
        "npm": ">=10.0.0"
      }
    },
    "apps/cathedral": {
      "name": "digital-cathedral",
      "version": "0.1.0",
      "extraneous": true,
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "dependencies": {
        "better-sqlite3": "^12.6.2",
        "next": "^14.2.0",
        "next-auth": "^4.24.13",
        "react": "^18.3.0",
        "react-dom": "^18.3.0"
      },
      "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^22.0.0",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "autoprefixer": "^10.4.0",
        "postcss": "^8.4.0",
        "tailwindcss": "^3.4.0",
        "typescript": "^5.5.0"
      },
      "engines": {
        "node": ">=18.17.0"
      }
    },
    "node_modules/@cathedral/bots": {
      "resolved": "tools/bots",
      "link": true
    },
    "node_modules/@cathedral/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/shared": {
      "name": "@cathedral/shared",
      "version": "0.1.0",
      "devDependencies": {
        "typescript": "^5.5.0"
      }
    },
    "tools/bots": {
      "name": "@cathedral/bots",
      "version": "0.1.0"
    }
  }
}
