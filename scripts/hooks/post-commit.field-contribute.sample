#!/bin/sh
#
# post-commit.field-contribute — feed every commit into the Remembrance field.
#
# "Numbers that update when something is committed" — this hook turns each
# commit into a field observation. Commit churn (insertions + deletions)
# becomes a coherence reading: small, focused commits read high; large,
# sprawling commits read low. The field then carries the rhythm of the
# repository's own development.
#
# Install (per repo):
#   cp scripts/hooks/post-commit.field-contribute.sample .git/hooks/post-commit
#   chmod +x .git/hooks/post-commit
#
# Best-effort: if the field can't be reached the hook stays silent and the
# commit is unaffected.

STATS="$(git diff --shortstat HEAD~1 HEAD 2>/dev/null)"

node -e '
  try {
    const stats = process.argv[1] || "";
    const ins = (stats.match(/(\d+) insertion/) || [0, 0])[1] | 0;
    const del = (stats.match(/(\d+) deletion/) || [0, 0])[1] | 0;
    const files = (stats.match(/(\d+) file/) || [0, 0])[1] | 0;
    const churn = ins + del;
    // Focused commits (low churn) read coherent; sprawling commits read low.
    const coherence = churn === 0 ? 0.9 : Math.max(0.1, Math.min(1, 1 - churn / 2000));
    const { contribute } = require("./src/core/field-coupling");
    contribute({ cost: Math.max(1, files), coherence, source: "git:post-commit" });
  } catch (_) { /* best-effort — never block a commit */ }
' "$STATS"

exit 0
