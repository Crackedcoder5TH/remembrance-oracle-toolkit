{
  "name": "remembrance-oracle",
  "displayName": "Remembrance Oracle",
  "description": "Pattern memory + code quality scoring for your codebase",
  "version": "0.1.0",
  "publisher": "remembrance-oracle",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Other"],
  "license": "MIT",
  "keywords": ["code memory", "patterns", "coherency", "oracle", "scoring"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "remembrance.scoreFile",
        "title": "Remembrance: Score Current File"
      },
      {
        "command": "remembrance.searchPattern",
        "title": "Remembrance: Search Patterns"
      },
      {
        "command": "remembrance.cascadeFile",
        "title": "Remembrance: Cascade Resonance"
      },
      {
        "command": "remembrance.resolvePattern",
        "title": "Remembrance: Resolve Pattern"
      }
    ],
    "configuration": {
      "title": "Remembrance Oracle",
      "properties": {
        "remembrance.oracleUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of the Remembrance Oracle API server"
        },
        "remembrance.voidUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "URL of the Void Compressor service"
        },
        "remembrance.autoScore": {
          "type": "boolean",
          "default": true,
          "description": "Automatically score files on save"
        },
        "remembrance.threshold": {
          "type": "number",
          "default": 0.68,
          "description": "Minimum coherency threshold for pattern suggestions"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
